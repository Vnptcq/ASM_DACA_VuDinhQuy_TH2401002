@{
    ViewData["Title"] = "Home";
}

<div class="text-center py-5">
    <h1 class="display-5">HR Management System</h1>
    <p class="lead text-muted">Manage departments, employees, and workforce statistics.</p>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a asp-controller="Department" asp-action="Index" class="btn btn-primary btn-lg me-2">Departments</a>
        <a asp-controller="Employee" asp-action="Create" class="btn btn-outline-primary btn-lg">Add Employee</a>
    }
    else
    {
        <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg">Sign In to Continue</a>
    }
</div>
