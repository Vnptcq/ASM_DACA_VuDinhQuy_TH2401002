@model IReadOnlyList<HR_Management.Application.DTOs.DepartmentStatisticsDTO>
@{
    ViewData["Title"] = "Department Statistics";
    var totalEmployees = Model.Sum(d => d.TotalEmployees);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Department Statistics</h2>
        <p class="text-muted mb-0">Employee breakdown by department</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to Departments</a>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card border-primary shadow-sm">
            <div class="card-body">
                <h6 class="text-muted text-uppercase">Total Departments</h6>
                <p class="display-6 mb-0">@Model.Count</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-success shadow-sm">
            <div class="card-body">
                <h6 class="text-muted text-uppercase">Total Employees</h6>
                <p class="display-6 mb-0">@totalEmployees</p>
            </div>
        </div>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-bordered table-hover">
        <thead class="table-primary">
            <tr>
                <th>Department Code</th>
                <th>Department Name</th>
                <th>Location</th>
                <th class="text-center">Total Employees</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Count == 0)
        {
            <tr>
                <td colspan="4" class="text-center text-muted py-4">No department data available.</td>
            </tr>
        }
        else
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td><span class="badge bg-secondary">@item.DepartmentCode</span></td>
                    <td>@item.DepartmentName</td>
                    <td>@item.Location</td>
                    <td class="text-center">
                        <span class="badge rounded-pill bg-info text-dark fs-6">@item.TotalEmployees</span>
                    </td>
                </tr>
            }
            <tr class="table-light fw-bold">
                <td colspan="3" class="text-end">Grand Total</td>
                <td class="text-center">@totalEmployees</td>
            </tr>
        }
        </tbody>
    </table>
</div>
