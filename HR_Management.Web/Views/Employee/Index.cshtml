@model IReadOnlyList<HR_Management.Application.DTOs.EmployeeDTO>
@{
    ViewData["Title"] = "Employees";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Employees</h2>
    <a asp-action="Create" class="btn btn-primary">Add Employee</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Code</th>
                <th>Name</th>
                <th>Department</th>
                <th>Rank</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Count == 0)
        {
            <tr>
                <td colspan="4" class="text-center text-muted py-4">No employees yet. Add an employee to a department.</td>
            </tr>
        }
        else
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td><span class="badge bg-secondary">@item.EmployeeCode</span></td>
                    <td>@item.EmployeeName</td>
                    <td>@item.DepartmentName</td>
                    <td>@item.Rank</td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>
